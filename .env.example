# ============================================
# WhatsApp AI Auto-Reply - Environment Config
# ============================================
# Copy this file to .env and fill in your values
# cp .env.example .env

# ---------- WAHA Configuration ----------
WAHA_API_KEY=change-me-to-a-secure-random-key
WAHA_SESSION_NAME=default

# ---------- AI Provider ----------
# Options: ollama, openai
AI_PROVIDER=ollama

# ---- Ollama Settings (for local AI) ----
# If using Docker Ollama, change to http://ollama:11434
# If running Ollama on host, use http://host.docker.internal:11434 (Linux/Mac)
# or http://host.docker.internal:11434 (Windows)
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=llama3.2:1b

# ---- OpenAI Settings (cloud AI) ----
# Only needed if AI_PROVIDER=openai
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4o-mini

# ---------- AI Parameters ----------
AI_TEMPERATURE=0.7
AI_MAX_TOKENS=150
SYSTEM_PROMPT="You are a helpful WhatsApp assistant. Keep replies short, friendly and professional. Never share personal info. Never discuss restricted topics. If asked about something you cannot answer, politely decline."

# ---------- Guard Rails ----------
MAX_CHARS=500
RATE_LIMIT_PER_MINUTE=10
RATE_LIMIT_COOLDOWN=10.0
APPROVAL_MODE=false

# ---------- WhatsApp ----------
WHATSAPP_SESSION=default
WAHA_BASE_URL=http://waha:3000
